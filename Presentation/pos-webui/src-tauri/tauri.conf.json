{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BizFlow",
  "version": "0.1.0",
  "identifier": "com.bizflow.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:47897",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "BizFlow POS",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:5130 http://localhost:5130 tauri://localhost ws://localhost:47897"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
    "binaries/BizFlow.Backend"
  ],
  "resources": [
      "binaries/appsettings.json"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
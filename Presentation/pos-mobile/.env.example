# =========================================================================
# BIZFLOW MOBILE - ENVIRONMENT VARIABLES
# =========================================================================

# The Base API URL (Must start with EXPO_PUBLIC_ for Expo) 
# Example (Local or physical device): http://192.168.1.XX:8080/api

# Example (Emulator): http://10.0.2.2:8080/api

# Example (Production): https://your-app.onrender.com/api
EXPO_PUBLIC_API_URL=your_api_url_here

# The Health Check Endpoint
# Example: http://192.168.1.XX:8080/health
EXPO_PUBLIC_HEALTH_URL=your_health_url_here
